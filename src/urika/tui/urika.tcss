/* Urika TUI theme */

Screen {
    background: $background;
    layout: vertical;
}

OutputPanel {
    height: 1fr;
    min-height: 5;
}

InputBar {
    height: 3;
    border-top: solid $accent;
    border-bottom: solid $accent;
    padding: 0 1;
}

StatusBar {
    height: 3;
    background: $surface;
    padding: 0 1;
}

Footer {
    display: none;
}
